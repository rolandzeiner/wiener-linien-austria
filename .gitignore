# Unified .gitignore for the *-austria HACS portfolio (5 integrations,
# all Lit 3 + TypeScript + Rollup card + HA Python integration).
# Reviewed 2026-05-08 — composed from the union of all 5 existing files,
# de-duplicated, with per-repo paths replaced by globbed equivalents.

# ───────────────────────────────────────────────────────────────────
# Python
# ───────────────────────────────────────────────────────────────────
__pycache__/
**/__pycache__/
*.py[cod]
*.pyc
*$py.class
*.so
.Python

# Test / coverage
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
.coverage.*
coverage.xml
htmlcov/
.tox/

# Build / dist / packaging
build/
dist/
*.egg-info/
.eggs/
pip-log.txt
pip-delete-this-directory.txt

# Virtual envs
.venv/
venv/
env/
ENV/
.python-version
.HA_VERSION

# ───────────────────────────────────────────────────────────────────
# Node / JS / TypeScript
# ───────────────────────────────────────────────────────────────────
node_modules/
.npm/
*.js.map

# Bundler caches
.rollup.cache/
.vite-cache/
.parcel-cache/

# ───────────────────────────────────────────────────────────────────
# OS metadata
# ───────────────────────────────────────────────────────────────────
.DS_Store
**/.DS_Store
Thumbs.db
ehthumbs.db
desktop.ini
Desktop.ini
*.swp
*.swo
*~
*.bak

# ───────────────────────────────────────────────────────────────────
# IDE / editor state
# ───────────────────────────────────────────────────────────────────
.vscode/
.idea/
*.iml
.cursor/
.cursorrules.local
.continue/
.windsurf/

# ───────────────────────────────────────────────────────────────────
# AI assistants — local state, transcripts, plans, project-level skills
# ───────────────────────────────────────────────────────────────────
.claude/
# Defensive: re-ignore project-level skills explicitly so they stay
# out of git even if someone later adds a !.claude/<something>
# exception that would un-ignore the parent dir. Portfolio-wide rules
# belong in the user-level austria-portfolio-workflow skill, not here.
.claude/skills/
.claude-cache/
.claude-*
.aider*

# ───────────────────────────────────────────────────────────────────
# Static analysis tooling
# ───────────────────────────────────────────────────────────────────
.fallow/
.fallowrc.json
.fallowrc.jsonc
fallow.toml

# ───────────────────────────────────────────────────────────────────
# Secrets / credentials — NEVER commit
# ───────────────────────────────────────────────────────────────────
.env
.env.*
!.env.example
.secrets
*.secret
secrets.json
secrets.yaml
auth.json
credentials.json
token.json
*.pem
*.key
*.p12
*.pfx
tests/fixtures/secrets/

# ───────────────────────────────────────────────────────────────────
# HA local state — logs, config copies
# ───────────────────────────────────────────────────────────────────
.storage/
home-assistant.log*
home-assistant_*.log*
*.log
config/

# ───────────────────────────────────────────────────────────────────
# Personal dev tooling — push/sync scripts targeting a dev box, scratch
# ───────────────────────────────────────────────────────────────────
scripts/
dev-push.sh
dev/
test/
target/

# Personal notes / scratch — *.local.md is the convention
CLAUDE.local.md
*.local.md
local_*.py
private_*.py

# ───────────────────────────────────────────────────────────────────
# Dev-only fixture hook (gitignored by design — per-repo file is local)
# ───────────────────────────────────────────────────────────────────
custom_components/*/_dev_fixture.py
